<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sample REST API — Ejemplo de API de mediación
  Expone un endpoint REST que redirige a un backend
-->
<api xmlns="http://ws.apache.org/ns/synapse"
     name="SampleAPI"
     context="/sample">

    <resource methods="GET" uri-template="/health">
        <inSequence>
            <payloadFactory media-type="json">
                <format>
                    {"status": "UP", "service": "SampleAPI", "timestamp": "$1"}
                </format>
                <args>
                    <arg evaluator="xml" expression="get-property('SYSTEM_DATE', 'yyyy-MM-dd\'T\'HH:mm:ss.SSSZ')"/>
                </args>
            </payloadFactory>
            <respond/>
        </inSequence>
    </resource>

    <resource methods="GET" uri-template="/data">
        <inSequence>
            <log level="custom">
                <property name="MESSAGE" value="Invocando backend para /data"/>
            </log>
            <call>
                <endpoint key="SampleBackendEP"/>
            </call>
            <respond/>
        </inSequence>
        <faultSequence>
            <sequence key="CommonErrorHandler"/>
        </faultSequence>
    </resource>

    <resource methods="POST" uri-template="/data">
        <inSequence>
            <log level="custom">
                <property name="MESSAGE" value="POST recibido en /data"/>
                <property name="PAYLOAD" expression="json-eval($.)"/>
            </log>
            <call>
                <endpoint key="SampleBackendEP"/>
            </call>
            <respond/>
        </inSequence>
        <faultSequence>
            <sequence key="CommonErrorHandler"/>
        </faultSequence>
    </resource>

</api>
