-- )
-- define stream HttpOutputEventStream (
--     eventId string,
--     eventType string,
--     payload string,
--     processedAt long
-- );

-- =============================================================================
-- Query: Procesar eventos válidos
-- PERSONALIZAR: Agregar lógica de transformación/filtrado
-- =============================================================================
@info(name = 'processValidEvents')
from InputEventStream[not(eventId is null) and not(eventType is null)]
select
    eventId,
    eventType,
    payload,
    timestamp,
    currentTimeMillis() as processedAt
insert into ProcessedEventStream;

-- =============================================================================
-- Query: Detectar eventos inválidos
-- =============================================================================
@info(name = 'detectInvalidEvents')
from InputEventStream[eventId is null or eventType is null]
select
    ifThenElse(eventId is null, 'UNKNOWN', eventId) as eventId,
    ifThenElse(eventType is null, 'UNKNOWN', eventType) as eventType,
    'Evento con campos obligatorios nulos' as errorMessage,
    currentTimeMillis() as timestamp
insert into ErrorEventStream;

-- =============================================================================
-- Query: Enviar eventos procesados al output
-- =============================================================================
@info(name = 'outputProcessedEvents')
from ProcessedEventStream
select eventId, eventType, payload, processedAt
insert into OutputEventStream;

-- =============================================================================
-- Query: Enviar errores al log
-- =============================================================================
@info(name = 'logErrors')
from ErrorEventStream
select eventId, eventType, errorMessage, timestamp
insert into ErrorLogStream;

